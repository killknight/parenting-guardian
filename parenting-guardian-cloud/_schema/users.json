{
  "bsonType": "object",
  "required": ["phone", "password", "role", "createTime"],
  "permission": {
    "read": "auth.uid != null",
    "create": "auth.uid != null",
    "update": "auth.uid == doc._id || auth.uid != null",
    "delete": "auth.uid == doc._id"
  },
  "properties": {
    "_id": {
      "description": "用户ID，系统自动生成"
    },
    "phone": {
      "bsonType": "string",
      "label": "手机号",
      "description": "用户手机号，用于登录"
    },
    "password": {
      "bsonType": "string",
      "label": "密码",
      "description": "加密后的密码"
    },
    "role": {
      "enum": ["parent", "child"],
      "label": "角色",
      "description": "用户角色：parent=家长，child=孩子"
    },
    "nickname": {
      "bsonType": "string",
      "label": "昵称",
      "description": "用户昵称"
    },
    "avatar": {
      "bsonType": "string",
      "label": "头像",
      "description": "头像URL"
    },
    "emergencyPhone": {
      "bsonType": "string",
      "label": "紧急联系电话",
      "description": "紧急联系人的手机号"
    },
    "createTime": {
      "bsonType": "timestamp",
      "label": "创建时间",
      "description": "账户创建时间"
    },
    "updateTime": {
      "bsonType": "timestamp",
      "label": "更新时间",
      "description": "最后更新时间"
    }
  }
}
