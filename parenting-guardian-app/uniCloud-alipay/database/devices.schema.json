{
  "bsonType": "object",
  "required": ["userId", "deviceId", "registerTime"],
  "permission": {
    "read": "auth.uid != null",
    "create": "auth.uid != null",
    "update": "auth.uid != null",
    "delete": "auth.uid != null"
  },
  "properties": {
    "_id": {
      "description": "记录ID，系统自动生成"
    },
    "userId": {
      "bsonType": "string",
      "label": "用户ID",
      "description": "关联的用户ID"
    },
    "deviceId": {
      "bsonType": "string",
      "label": "设备ID",
      "description": "设备唯一标识"
    },
    "deviceName": {
      "bsonType": "string",
      "label": "设备名称",
      "description": "设备名称，如：小米11"
    },
    "deviceModel": {
      "bsonType": "string",
      "label": "设备型号",
      "description": "设备型号"
    },
    "osVersion": {
      "bsonType": "string",
      "label": "系统版本",
      "description": "Android系统版本"
    },
    "appVersion": {
      "bsonType": "string",
      "label": "App版本",
      "description": "App版本号"
    },
    "registerTime": {
      "bsonType": "timestamp",
      "label": "注册时间",
      "description": "设备注册时间"
    },
    "lastOnlineTime": {
      "bsonType": "timestamp",
      "label": "最后在线时间",
      "description": "最后在线时间"
    },
    "onlineStatus": {
      "bsonType": "bool",
      "label": "在线状态",
      "description": "设备是否在线"
    }
  }
}
