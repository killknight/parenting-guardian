{
  "bsonType": "object",
  "required": ["userId", "packageName", "appName", "timestamp"],
  "permission": {
    "read": "auth.uid != null",
    "create": "auth.uid != null",
    "update": "auth.uid != null",
    "delete": "auth.uid != null"
  },
  "properties": {
    "_id": {
      "description": "记录ID，系统自动生成"
    },
    "userId": {
      "bsonType": "string",
      "label": "用户ID",
      "description": "孩子用户ID"
    },
    "packageName": {
      "bsonType": "string",
      "label": "应用包名",
      "description": "应用包名，如：com.tencent.mm"
    },
    "appName": {
      "bsonType": "string",
      "label": "应用名称",
      "description": "应用显示名称，如：微信"
    },
    "startTime": {
      "bsonType": "timestamp",
      "label": "开始时间",
      "description": "应用使用开始时间"
    },
    "endTime": {
      "bsonType": "timestamp",
      "label": "结束时间",
      "description": "应用使用结束时间"
    },
    "duration": {
      "bsonType": "int",
      "label": "使用时长(秒)",
      "description": "使用时长，单位：秒"
    },
    "timestamp": {
      "bsonType": "timestamp",
      "label": "记录时间",
      "description": "记录生成时间"
    },
    "date": {
      "bsonType": "string",
      "label": "日期",
      "description": "日期，格式：YYYY-MM-DD"
    }
  }
}
