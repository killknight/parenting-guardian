{
  "name": "UsageStats",
  "id": "UsageStats",
  "version": "1.0.0",
  "description": "应用使用统计原生插件，获取前台应用和使用时长",
  "_dp_type": "nativeplugin",
  "_dp_nativeplugin": {
    "android": {
      "plugins": [
        {
          "type": "module",
          "name": "UsageStats",
          "class": "com.parenting.guardian.plugin.UsageStatsModule"
        }
      ],
      "permissions": [
        "<uses-permission android:name=\"android.permission.PACKAGE_USAGE_STATS\" />",
        "<uses-permission android:name=\"android.permission.QUERY_ALL_PACKAGES\" />"
      ],
      "minSdkVersion": 24
    }
  }
}
