<view class="container">
  <!-- 地图区域 -->
  <view class="map-section">
    <map
      id="map"
      class="map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="16"
      show-location
      markers="{{markers}}"
    ></map>
  </view>

  <!-- 位置信息卡片 -->
  <view class="location-card">
    <view class="card-header">
      <text class="card-title">当前位置</text>
      <text class="update-time">{{updateTime}}</text>
    </view>
    
    <view class="location-detail">
      <view class="detail-row">
        <text class="detail-label">地址</text>
        <text class="detail-value">{{address}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">经纬度</text>
        <text class="detail-value">{{longitude}}, {{latitude}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">定位方式</text>
        <text class="detail-value">{{gpsType}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">精度</text>
        <text class="detail-value">{{accuracy}}</text>
      </view>
    </view>
  </view>

  <!-- 轨迹记录 -->
  <view class="trail-section">
    <view class="section-header">
      <text class="section-title">今日轨迹</text>
      <text class="trail-count">{{trailCount}}个位置</text>
    </view>
    
    <scroll-view scroll-y class="trail-list">
      <view class="trail-item" wx:for="{{trailList}}" wx:key="index">
        <view class="trail-dot"></view>
        <view class="trail-info">
          <text class="trail-address">{{item.address}}</text>
          <text class="trail-time">{{item.time}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 刷新按钮 -->
  <view class="refresh-btn" bindtap="refreshLocation">
    <text class="btn-text">刷新位置</text>
  </view>
</view>