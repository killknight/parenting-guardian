.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  margin-bottom: 20rpx;
}

.status-card {
  background: linear-gradient(135deg, #4A90E2 0%, #67B26F 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  color: #fff;
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.status-icon.online {
  background-color: #52c41a;
  box-shadow: 0 0 20rpx rgba(82, 196, 26, 0.5);
}

.status-icon.offline {
  background-color: #999;
}

.status-info {
  flex: 1;
}

.device-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.status-text {
  font-size: 24rpx;
  opacity: 0.8;
}

.last-update {
  font-size: 22rpx;
  opacity: 0.7;
}

.stats-section, .action-section, .device-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 50%;
  text-align: center;
  padding: 20rpx 0;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90E2;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
}

.action-item {
  width: 25%;
  text-align: center;
  padding: 20rpx 0;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin: 0 auto 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lock-icon {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF4757 100%);
}

.location-icon {
  background: linear-gradient(135deg, #4A90E2 0%, #667eea 100%);
}

.usage-icon {
  background: linear-gradient(135deg, #67B26F 0%, #4A90E2 100%);
}

.alert-icon {
  background: linear-gradient(135deg, #F6D365 0%, #FDA085 100%);
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.device-card {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.device-row {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}

.device-row:last-child {
  border-bottom: none;
}

.device-label {
  font-size: 28rpx;
  color: #666;
}

.device-value {
  font-size: 28rpx;
  color: #333;
}